# =====================================================
# ENVIRONNEMENT PYTHON
# =====================================================
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd

# =====================================================
# FICHIERS SYSTEME
# =====================================================
.DS_Store
Thumbs.db

# =====================================================
# CONFIG / SECRETS
# =====================================================
.env
.env.local
.env.*.local

# =====================================================
# BASE DE DONNEES
# =====================================================
data/database.db
*.sqlite
*.db

# =====================================================
# LOGS
# =====================================================
data/app.log
*.log

# =====================================================
# DONNEES DYNAMIQUES (NE PAS VERSIONNER)
# =====================================================
data/backups/*
data/reservations/*
data/stock/*
data/inventaires/*

# GARDER LA STRUCTURE DES DOSSIERS
!data/backups/.gitkeep
!data/reservations/.gitkeep
!data/stock/.gitkeep
!data/inventaires/.gitkeep

# =====================================================
# ASSETS DYNAMIQUES
# =====================================================
assets/photos/*
assets/icons/*

!assets/photos/.gitkeep
!assets/icons/.gitkeep

# QR codes générés
assets/photos/qr/*

# =====================================================
# DOSSIER STATIC
# =====================================================
static/photos/*

!static/photos/.gitkeep

# =====================================================
# EXPORTS / FICHIERS TEMPORAIRES
# =====================================================
*.csv
*.xlsx
*.zip

# =====================================================
# IDE / EDITEURS
# =====================================================
.vscode/
.idea/
*.swp
*.swo

# =====================================================
# STREAMLIT
# =====================================================
.streamlit/

# =====================================================
# CACHE
# =====================================================
.cache/
